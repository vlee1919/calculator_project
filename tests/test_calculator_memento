import logging
import pandas as pd
import pytest

from app.calculator_config import CalculatorConfig
from app.calculator_memento import (
    EventManager,
    HistoryManager,
    Memento,
    MementoManager,
    AutoSaveObserver,
    LoggingObserver,
)

@pytest.fixture
def history_manager(tmp_path):
    config = CalculatorConfig(base_directory=tmp_path)
    return HistoryManager(config)

def test_attach_observer(history_manager):

    manager = EventManager()

    manager.attach(history_manager)

    assert len(manager.subscribers) == 1
    assert manager.subscribers[0] == history_manager

def test_notify_observer(history_manager):

    manager = EventManager()
    manager.attach(history_manager)

    record = {
        "Operation": "add",
        "Input": "2, 3",
        "Result": 5
    }

    manager.notify(record)

    assert len(history_manager.df) == 1
    assert history_manager.df.iloc[0]["Operation"] == "add"

def test_history_update(history_manager):

    record = {
        "Operation": "multiply",
        "Input": "4, 5",
        "Result": 20
    }

    history_manager.update(record)

    assert len(history_manager.df) == 1

    row = history_manager.df.iloc[0]

    assert row["Operation"] == "multiply"
    assert row["Input"] == "4, 5"
    assert row["Result"] == 20
    assert "Timestamp" in row

def test_history_save(history_manager):

    history_manager.update({
        "Operation": "add",
        "Input": "1, 2",
        "Result": 3
    })

    history_manager.save()

    assert history_manager.filepath.exists()
    df = pd.read_csv(history_manager.filepath)

    assert len(df) == 1


def test_load_history(history_manager):

    history_manager.update({
        "Operation": "subtract",
        "Input": "10, 5",
        "Result": 5
    })

    history = history_manager.load_history()

    assert len(history) == 1
    assert history[0]["Operation"] == "subtract"

"""Test for MementoManager Class"""

def test_backup():

    manager = MementoManager()
    state = [{"Result": 5}]
    manager.backup(state)

    assert len(manager.undo_stack) == 1
    assert len(manager.redo_stack) == 0

def test_undo():

    manager = MementoManager()
    state = [{"Result": 5}]
    manager.backup(state)

    previous = manager.undo([])

    assert previous == state
    assert len(manager.redo_stack) == 1

def test_redo():

    manager = MementoManager()

    state = [{"Result": 5}]
    manager.backup(state)
    manager.undo([])

    restored = manager.redo([])

    assert restored == state

"""Test for AutoSaveObserver class and LoggingObserver Class"""

def test_autosave_observer(history_manager):

    observer = AutoSaveObserver(history_manager)
    observer.update({})

    assert history_manager.filepath.exists()

def test_logging_observer():

    observer = LoggingObserver()

    observer.update({
        "Operation": "add",
        "Input": "2, 3",
        "Result": 5
    })

